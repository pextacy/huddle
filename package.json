{
  "name": "huddle",
  "version": "0.1.0",
  "description": "Offline-first group expense splitter with self-custodial USD₮ settlement: P2P ledger (Holepunch) + wallet (Tether WDK), Node backend + Next.js frontend.",
  "type": "module",
  "main": "server/index.mjs",
  "license": "MIT",
  "scripts": {
    "test": "node --test 'test/**/*.test.js'",
    "wallet:status": "node scripts/wallet.mjs status",
    "wallet:send": "node scripts/wallet.mjs send",
    "p2p:verify": "node scripts/verify-p2p.mjs",
    "settle:verify": "node scripts/verify-settle.mjs",
    "server": "node server/index.mjs",
    "app": "node scripts/dev.mjs"
  },
  "dependencies": {
    "@tetherto/wdk": "1.0.0-beta.14",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.14",
    "autobase": "7.28.1",
    "b4a": "1.8.1",
    "corestore": "7.11.0",
    "hyperbee": "2.27.3",
    "hypercore-crypto": "3.7.0",
    "hyperswarm": "4.17.0",
    "qrcode-generator": "2.0.4"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
